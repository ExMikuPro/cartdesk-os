//    用于：I2C/SPI/UART/QSPI/文件/设备句柄等
// -----------------------------

typedef struct {
  void* handle;   // 你要保存的底层句柄（TIM_HandleTypeDef* / FATFS* / 自己的结构体*）
  uint32_t flags; // 可选：状态/标志
} xxx_ud_t;

#define XXX_MT "xxx.mt"

// 确保 userdata 类型正确
static xxx_ud_t* check_xxx_ud(lua_State* L, int idx) {
  return (xxx_ud_t*)luaL_checkudata(L, idx, XXX_MT);
}

// h:close()
static int l_xxx_close(lua_State* L) {
  xxx_ud_t* ud = check_xxx_ud(L, 1);

  if (ud->handle) {
    // TODO: 释放/关闭底层资源
    ud->handle = NULL;
  }
  return 0;
}

// h:read(n) -> string
static int l_xxx_read(lua_State* L) {
  xxx_ud_t* ud = check_xxx_ud(L, 1);
  uint32_t n = check_u32(L, 2);

  if (!ud->handle) {
    return luaL_error(L, "xxx handle is closed");
  }

  // TODO: 从底层读 n 字节到 buffer
  // 这里给模板：返回空字符串
  (void)n;
  lua_pushlstring(L, "", 0);
  return 1;
}

// h:write(data) -> written_len
static int l_xxx_write(lua_State* L) {
  xxx_ud_t* ud = check_xxx_ud(L, 1);
  size_t len = 0;
  const char* data = luaL_checklstring(L, 2, &len);

  if (!ud->handle) {
    return luaL_error(L, "xxx handle is closed");
  }

  // TODO: 写入 data
  lua_pushinteger(L, (lua_Integer)len);
  return 1;
}

static const luaL_Reg xxx_methods[] = {
  {"close", l_xxx_close},
  {"read",  l_xxx_read},
  {"write", l_xxx_write},
  {NULL, NULL}
};

// xxx.open(...) -> returns userdata
static int l_xxx_open(lua_State* L) {
  // TODO: 解析 open 参数
