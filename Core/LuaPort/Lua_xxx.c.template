// B) 通用：不依赖 lua_port.h（cfg 类型用 void*，你自己 cast）
static inline void* xxx_get_cfg_void(lua_State* L) {
  lua_getfield(L, LUA_REGISTRYINDEX, "port.cfg");
  void* cfg = lua_touserdata(L, -1);
  lua_pop(L, 1);
  return cfg;
}

// -----------------------------
// 1) 参数检查/错误模板（你可以按需扩展）
// -----------------------------
static inline uint32_t check_u32(lua_State* L, int idx) {
  lua_Integer v = luaL_checkinteger(L, idx);
  if (v < 0) luaL_error(L, "arg %d must be >= 0", idx);
  return (uint32_t)v;
}

static inline const char* check_cstr(lua_State* L, int idx) {
  return luaL_checkstring(L, idx);
}

