  // 创建 userdata
  xxx_ud_t* ud = (xxx_ud_t*)lua_newuserdatauv(L, sizeof(xxx_ud_t), 0);
  memset(ud, 0, sizeof(*ud));

  // TODO: 打开底层资源，把句柄存进去
  // ud->handle = (void*)some_handle;

  // 绑定 metatable
  luaL_getmetatable(L, XXX_MT);
