// 绑定 metatable（只做一次）
static void xxx_create_metatable(lua_State* L) {
  if (luaL_newmetatable(L, XXX_MT)) {
    // mt.__index = methods_table
    lua_newtable(L);
    luaL_setfuncs(L, xxx_methods, 0);
    lua_setfield(L, -2, "__index");

    // mt.__gc = close
    lua_pushcfunction(L, l_xxx_close);
    lua_setfield(L, -2, "__gc");
  }
  lua_pop(L, 1); // pop metatable
}

// -----------------------------
// 4) 模块导出（你可以选择导出表模块 或 同时导出 open）
// -----------------------------

int luaopen_xxx(lua_State* L) {
  // 如果你用到 userdata 句柄，先建 metatable
  xxx_create_metatable(L);

  // 创建模块表
  luaL_newlib(L, xxx_funcs);

  // 可选：把 open 也挂到模块上（xxx.open -> userdata）
  lua_pushcfunction(L, l_xxx_open);
  lua_setfield(L, -2, "open");

  return 1; // 返回模块表
}
